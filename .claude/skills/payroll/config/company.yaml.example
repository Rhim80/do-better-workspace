# Payroll - 회사 정보 (각자 채워서 사용)
# 사용법:
#   1. 이 파일을 복사: cp company.yaml.example company.yaml
#   2. {{}} 안의 placeholder를 자기 회사 정보로 교체
#   3. company.yaml은 .gitignore로 보호되어 commit되지 않음
#
# 또는 대화형 셋업: /payroll setup

# ─────────────────────────────────────────────
# 1. 회사 기본 정보
# ─────────────────────────────────────────────
company:
  name: "{{회사명}}"                    # 예: "A카페", "주식회사 OO"
  short_name: "{{회사약칭}}"             # 예: "A". 퇴직금산정내역서 파일명/양식에 사용 (없으면 name 사용)
  business_owner: "{{사업주명}}"         # 예: "홍길동". 퇴직금산정내역서 양식의 "사업주명" 칸
  industry_code: "{{업종}}"             # 예: "음식점업", "도소매업"
  under_5_employees: true               # 5인 미만 사업장 여부 (법정 가산수당 의무 X)

# ─────────────────────────────────────────────
# 1-1. 회사 가산수당 기준 (회사가 실제로 운영하는 기준)
# ─────────────────────────────────────────────
# 한국 노동법 "법정 최저 기준"은 rates-kr-2026.yaml 의 labor_law_minimum 참고
# - 5인 이상: 연장 1.5배, 휴일 1.5배(8h 이내)/2.0배(초과), 야간 +0.5배
# - 5인 미만: 가산 의무 없음 (회사 자율)
#
# 회사가 실제 적용하는 가산율을 적으세요. 급여변동.md의 "가산율" 컬럼과 일치해야 함.
# 코드는 이 값을 자동 계산에 쓰지 않고, 사용자가 적은 수당 금액을 그대로 합산합니다.
# 이 섹션은 (1) 셋업 시 자기 회사 기준 명시 (2) 사용자가 일관되게 입력하도록 가이드 역할.
pay_rules:
  overtime_rate: 1.0                    # 추가근무 가산율 (예: 1.0=가산 X, 1.5=50% 가산)
  holiday_rate: 1.5                     # 휴일근무 가산율
  holiday_bonus_only_rate: null         # (선택) "기본급은 월급 포함, 가산분만 별도 지급"하는 경우 0.5
  night_extra_rate: 0.5                 # 야간근무 가산율
  notes: |
    회사가 실제로 운영하는 기준을 적습니다. 예시:
      - 5인 이상 일반 회사: overtime 1.5, holiday 1.5
      - 5인 미만 + 가산 안 줌: overtime 1.0, holiday 1.0
      - 5인 미만 + 휴일은 가산분만 0.5 별도: holiday_rate 1.0, holiday_bonus_only_rate 0.5

  # 매장(사업장)이 여러 개면 나열, 단일이면 빈 배열 []
  branches: []
  # 예시:
  # branches:
  #   - "본점"
  #   - "지점A"
  #   - "지점B"

  # 시트명 약어 매핑 (선택)
  # 매장명이 길어 Excel 시트명으로 쓰기 어려우면 짧은 이름 매핑
  branch_prefix: {}
  # 예시:
  # branch_prefix:
  #   "강남점": "강남"
  #   "홍대점": "홍대"

# ─────────────────────────────────────────────
# 2. 세무사 (선택 - 메일 발송 안 쓰면 비워둠)
# ─────────────────────────────────────────────
accountant:
  email: "{{세무사이메일}}"             # 예: "tax@example.com"
  name: "{{세무사명}}"                  # 예: "홍길동 세무사"
  company: "{{세무회계법인명}}"          # 예: "OO세무회계"

# 발신자 정보 (메일 발송 시 서명용)
sender:
  name: "{{회사명}}"                    # 보통 회사명과 동일
  signature: |
    감사합니다.

    {{회사명}} 드림

# 메일 템플릿 (필요 시 수정)
mail_templates:
  monthly_payroll:
    subject: "{year}년 {month}월 급여대장"
    body: |
      안녕하세요,

      {month}월 급여대장 전달드립니다.
      확인 부탁드립니다.

      감사합니다.
      {{회사명}} 드림

# ─────────────────────────────────────────────
# 3. Google Workspace 연동
# ─────────────────────────────────────────────
google_workspace:
  # Google Sheets 직원DB 스프레드시트 ID
  # /payroll setup이 자동 생성하거나, 직접 만들고 ID만 넣어도 됨
  spreadsheet_id: "{{SPREADSHEET_ID}}"

  sheets:
    employees: "직원DB"                 # 직원 기본정보 시트명
    payroll_prefix: "_급여대장"          # 월별 시트 suffix (YYYY-MM_급여대장)

# ─────────────────────────────────────────────
# 4. 출력 경로
# ─────────────────────────────────────────────
paths:
  # 급여 산출물(Excel, md) 저장 베이스 경로
  # 워크스페이스 내부면 상대경로, 외부면 절대경로
  output_base: "20-operations/payroll"

  # 하위 폴더 패턴 ({year} 자동 치환)
  excel_folder: "{year}/세무사자료"          # 급여대장.xlsx 출력
  payroll_record: "{year}/급여변동"          # 급여변동.md 입력
  resignation_folder: "{year}/입퇴사"        # 퇴직금계산.md 출력

# ─────────────────────────────────────────────
# 5. 메타데이터
# ─────────────────────────────────────────────
metadata:
  setup_date: ""                        # /payroll setup 실행 시 자동 기록
  config_version: "1.0"
