# PKM System Environment Variables
# .env.template을 복사해서 .env 파일로 만들고 실제 값들을 입력하세요
#
# 사용법:
# cp .env.template .env
# nano .env  # 실제 값 입력

# ==================================================
# AI APIs
# ==================================================

# Anthropic Claude API
# 발급: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI API (DALL-E 3, GPT-4 등)
# 발급: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-proj-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Gemini API
# 발급: https://makersuite.google.com/app/apikey
GEMINI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# Telegram Bot (Inbox Collector)
# ==================================================

# Telegram Bot Token
# 생성 방법: 00-system/02-scripts/telegram-bot-setup-guide.md 참조
# BotFather에서 발급받은 토큰
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklMNOpqrsTUVwxyz1234567

# Telegram Chat ID
# 본인과 Bot의 1:1 채팅방 ID
# 확인 방법: https://api.telegram.org/bot<TOKEN>/getUpdates
TELEGRAM_CHAT_ID=987654321

# ==================================================
# Ghost Blog
# ==================================================

# Ghost Admin API
# 발급: Ghost Admin > Integrations > Custom Integration
GHOST_API_URL=https://your-ghost-blog.example.com
GHOST_ADMIN_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# n8n Automation
# ==================================================

# n8n Webhook URLs (필요 시)
N8N_WEBHOOK_URL=https://your-n8n-instance.example.com/webhook/xxxxxxxx

# ==================================================
# Other Services
# ==================================================

# YouTube Data API
# 발급: https://console.cloud.google.com/apis/credentials
YOUTUBE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Notion API
# 발급: https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_WORKSPACE_PAGE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ==================================================
# 상권 분석 — 공공 API 9종 (난로회 부트캠프 2026-05-04)
# ==================================================
# 모두 무료. 공공데이터포털(data.go.kr) + 서울열린데이터광장(data.seoul.go.kr) 통합 가입 후 발급.

# 1. data.go.kr 통합 키 (행안부 인구·소진공 상가·공정위 가맹·국토부 실거래·관광공사 외국인)
# 발급: https://www.data.go.kr/ — 회원가입 후 각 API 활용신청 (자동승인)
DATAGOKR_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 2. 서울열린데이터광장 통합 키 (KT 생활인구·우리마을가게 추정매출·상권변화지표)
# 발급: https://data.seoul.go.kr/ — 회원가입 후 인증키 신청 (즉시)
SEOUL_OPENDATA_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 3. 한국부동산원 R-One (상가 임대 시세 통계)
# 발급: https://www.reb.or.kr/r-one/portal/openapi/openApiIntroPage.do
RONE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 4. 통계청 SGIS (사업체·종사자·소득) — 선택
# 발급: https://sgis.kostat.go.kr/developer/
SGIS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SGIS_API_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Google Trends — 키 불필요 (pytrends 라이브러리)
# 네이버 부동산 — 비공식 API, 키 불필요. Header 위장 필요.

